<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Responsive Portfolio</title>

<style>
/* =========================
   CSS VARIABLES
========================= */
:root{
    --bg-color:#ffffff;
    --text-color:#222;
    --card-color:#f4f4f4;
    --accent-color:#0077ff;
    --shadow:0 4px 10px rgba(0,0,0,0.1);
}

.dark-theme{
    --bg-color:#121212;
    --text-color:#ffffff;
    --card-color:#1e1e1e;
    --accent-color:#4da6ff;
    --shadow:0 4px 10px rgba(255,255,255,0.1);
}

/* =========================
   GLOBAL STYLES
========================= */
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:Arial, sans-serif;
    background:var(--bg-color);
    color:var(--text-color);
    transition:0.3s ease;
    line-height:1.6;
}

/* =========================
   NAVBAR (FLEXBOX)
========================= */
.navbar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px;
    background:var(--accent-color);
    color:white;
}

.nav-links{
    display:flex;
    gap:20px;
    list-style:none;
}

.nav-links a{
    color:white;
    text-decoration:none;
}

#themeBtn{
    padding:8px 15px;
    border:none;
    border-radius:5px;
    cursor:pointer;
}

/* =========================
   MAIN LAYOUT (CSS GRID)
========================= */
.container{
    display:grid;
    grid-template-columns:1fr;
    gap:20px;
    padding:20px;
}

/* Sidebar */
.sidebar{
    background:var(--card-color);
    padding:20px;
    border-radius:10px;
    box-shadow:var(--shadow);
    text-align:center;
}

.profile-img{
    width:120px;
    height:120px;
    border-radius:50%;
    margin-bottom:10px;
}

/* Content */
.content{
    display:flex;
    flex-direction:column;
    gap:20px;
}

/* =========================
   CARDS
========================= */
.card{
    background:var(--card-color);
    padding:20px;
    border-radius:10px;
    box-shadow:var(--shadow);
}

/* =========================
   SKILLS (FLEXBOX)
========================= */
.skills{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
}

.skill{
    background:var(--accent-color);
    color:white;
    padding:10px 15px;
    border-radius:20px;
}

/* =========================
   PROJECTS (GRID)
========================= */
.projects{
    display:grid;
    grid-template-columns:1fr;
    gap:20px;
}

.project-card{
    background:var(--card-color);
    padding:20px;
    border-radius:10px;
    box-shadow:var(--shadow);
    transition:0.3s;
}

.project-card:hover{
    transform:translateY(-8px);
}

/* =========================
   CONTACT
========================= */
.contact p{
    margin:10px 0;
}

/* =========================
   TABLET
========================= */
@media(min-width:768px){
    .container{
        grid-template-columns:250px 1fr;
    }

    .projects{
        grid-template-columns:repeat(2,1fr);
    }
}

/* =========================
   DESKTOP
========================= */
@media(min-width:1024px){
    .projects{
        grid-template-columns:repeat(3,1fr);
    }
}
</style>
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar">
    <h2>My Portfolio</h2>

    <ul class="nav-links">
        <li><a href="#about">About</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#projects">Projects</a></li>
        <li><a href="#contact">Contact</a></li>
    </ul>

    <button id="themeBtn">🌙 Dark Mode</button>
</nav>

<!-- MAIN CONTAINER -->
<div class="container">

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <img src="https://via.placeholder.com/120" class="profile-img" alt="Profile">
        <h2>J. Sandhya</h2>
        <p>Computer Science Engineering Student</p>
    </aside>

    <!-- CONTENT -->
    <main class="content">

        <!-- ABOUT -->
        <section class="card" id="about">
            <h2>About Me</h2>
            <p>
                I am a Computer Science Engineering student passionate about
                web development, artificial intelligence, and software design.
            </p>
        </section>

        <!-- SKILLS -->
        <section class="card" id="skills">
            <h2>Skills</h2>
            <div class="skills">
                <span class="skill">HTML5</span>
                <span class="skill">CSS3</span>
                <span class="skill">JavaScript</span>
                <span class="skill">Python</span>
                <span class="skill">Java</span>
                <span class="skill">SQL</span>
            </div>
        </section>

        <!-- PROJECTS -->
        <section class="card" id="projects">
            <h2>Projects</h2>

            <div class="projects">

                <div class="project-card">
                    <h3>Smart Canteen System</h3>
                    <p>
                        Online food ordering and queue management system
                        for colleges.
                    </p>
                </div>

                <div class="project-card">
                    <h3>Crop Disease Detection</h3>
                    <p>
                        AI-based disease detection using image processing.
                    </p>
                </div>

                <div class="project-card">
                    <h3>Flame Detection System</h3>
                    <p>
                        IoT project for real-time fire detection and alerts.
                    </p>
                </div>

                <div class="project-card">
                    <h3>Waste Water Irrigation</h3>
                    <p>
                        Smart irrigation system using recycled water.
                    </p>
                </div>

            </div>
        </section>

        <!-- CONTACT -->
        <section class="card contact" id="contact">
            <h2>Contact</h2>
            <p>Email: sandhyamsec@gmail.com</p>
            <p>Phone: +91 7904944861</p>
            <p>Location: Chennai, Tamil Nadu</p>
        </section>

    </main>
</div>

<script>
const themeBtn = document.getElementById("themeBtn");

themeBtn.addEventListener("click", () => {
    document.body.classList.toggle("dark-theme");

    if(document.body.classList.contains("dark-theme")){
        themeBtn.textContent = "☀ Light Mode";
    }else{
        themeBtn.textContent = "🌙 Dark Mode";
    }
});
</script>

</body>
</html>
